{
  "version": 2,
  "builds": [
    {
      "src": "coinscreener/wsgi.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "coinscreener/wsgi.py"
    }
  ],
  "functions": {
    "coinscreener/wsgi.py": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/cron/scan/",
      "schedule": "0 0 * * *"
    }
  ]
}